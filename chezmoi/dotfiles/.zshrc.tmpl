{{- /* Zsh configuration template */ -}}
# Source shell configuration files from ~/.shell/
[ -d "$HOME/.shell" ] && for file in $(ls -a "$HOME/.shell"); do source "$HOME/.shell/$file"; done

export TERM=xterm-256color
export UPDATE_ZSH_DAYS=1
export ZSH=$HOME/.oh-my-zsh

COMPLETION_WAITING_DOTS="true"
DISABLE_UNTRACKED_FILES_DIRTY="true"

plugins=(
    themes
    zsh-navigation-tools
    zsh-autosuggestions
    zsh-interactive-cd
    zsh-syntax-highlighting
    git
    eza
    colored-man-pages
    direnv
    {{- if .data.is_macos }}
    1password
    {{- end }}
    gnu-utils
    gradle
    kubectl
    ssh
    # starship
    # fzf
    # mise
    # zoxide
)

# Initialize tools
eval "$(starship init zsh)"
eval "$(zoxide init zsh)"
eval "$(mise activate zsh)"
eval "$(fzf --zsh)"

# FPATH="$HOME/.oh-my-zsh/custom/plugins/zsh-completions/src:$FPATH"
# autoload -Uz compinit && compinit

export PATH="/usr/local/sbin:$PATH:$HOME/.local/bin"

[ -f "$ZSH/oh-my-zsh.sh" ] && . $ZSH/oh-my-zsh.sh

# Source private zsh config if exists
[ -f ~/.zshrc.private ] && . ~/.zshrc.private

# Yandex Cloud CLI
if [ -f "$HOME/yandex-cloud/path.bash.inc" ]; then source "$HOME/yandex-cloud/path.bash.inc"; fi
if [ -f "$HOME/yandex-cloud/completion.zsh.inc" ]; then source "$HOME/yandex-cloud/completion.zsh.inc"; fi

# Yandex Cloud Private CLI
if [ -f "$HOME/ycp/path.bash.inc" ]; then source "$HOME/ycp/path.bash.inc"; fi

# LM Studio
if [ -d "~/.lmstudio/bin" ]; then export PATH="$PATH:~/.lmstudio/bin"; fi

{{- if .data.is_macos }}
# macOS-specific PATH additions
export PATH="/opt/homebrew/bin:$PATH"
{{- end }}
